#!/bin/bash
# Pre-commit checks for keldron-agent
# Install: git config core.hooksPath .githooks

set -eo pipefail

echo "🔍 Running pre-commit checks..."

# Format check (module packages only — not .gomodcache, vendor, or other trees)
echo "  → gofmt"
UNFORMATTED=$(go list -f '{{.Dir}}' ./... 2>/dev/null | sort -u | xargs gofmt -l 2>/dev/null | grep -v '^$' || true)
if [ -n "$UNFORMATTED" ]; then
    echo "❌ These files need gofmt:"
    echo "$UNFORMATTED"
    exit 1
fi

# Vet
echo "  → go vet"
go vet ./...

# Tests (short mode for speed)
echo "  → go test -short -race"
go test ./... -short -race -count=1 2>&1 | tail -5

echo "✅ All pre-commit checks passed"
